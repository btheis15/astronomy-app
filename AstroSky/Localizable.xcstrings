      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Datos de estrellas: Yale Bright Star Catalogue y la base de datos HYG (CC BY-SA 4.0). Cielo profundo: Messier, Caldwell y NGC. Efemérides: Meeus / JPL. Elementos de satélite: Celestrak. Texturas de planetas: Solar System Scope (CC BY 4.0)."

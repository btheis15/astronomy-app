    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "AstroSky uses the camera to overlay stars, planets and satellites on the real sky in augmented reality."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "AstroSky usa la cámara para superponer estrellas, planetas y satélites sobre el cielo real en realidad aumentada."
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Your location is used to compute where stars, planets and satellites appear in your sky."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Tu ubicación se usa para calcular dónde aparecen las estrellas, los planetas y los satélites en tu cielo."
          }
        }
      }
    }
